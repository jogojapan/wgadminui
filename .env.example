# =============================================================================
# wgadminui — environment variables template
# Copy this file to .env and fill in all values before starting the container.
# =============================================================================

# ── Core Django ──────────────────────────────────────────────────────────────
# Long random secret key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
WGADMINUI_SECRET_KEY=change-me-to-a-random-secret-key

# Comma-separated list of hostnames (your domain + localhost for health checks)
WGADMINUI_ALLOWED_HOSTS=wgadminui.example.com,localhost

# Set to False in production
WGADMINUI_DEBUG=False

# Port gunicorn binds to inside the container (and mapped to the host)
WGADMINUI_PORT=8000

# Timezone for display and logs (e.g. UTC, Europe/Berlin, America/New_York)
WGADMINUI_TIME_ZONE=UTC

# ── Initial admin account ─────────────────────────────────────────────────────
# Created on first container start. Change the password after first login.
WGADMINUI_ADMIN_EMAIL=admin@example.com
WGADMINUI_ADMIN_PASSWORD=change-me-immediately

# ── WireGuard ─────────────────────────────────────────────────────────────────
# Interface name (matches the filename in /etc/wireguard, e.g. wg0 → wg0.conf)
WGADMINUI_WG_INTERFACE=wg0

# Public IP or hostname clients will use to reach the WireGuard server
WGADMINUI_WG_SERVER_PUBLIC_IP=1.2.3.4

# WireGuard listen port (must match [Interface] ListenPort in your wg0.conf)
WGADMINUI_WG_SERVER_PORT=51820

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Required for invitation emails and email verification.
# Change backend to smtp.EmailBackend for production:
WGADMINUI_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
WGADMINUI_EMAIL_HOST=smtp.example.com
WGADMINUI_EMAIL_PORT=587
WGADMINUI_EMAIL_USER=youruser@example.com
WGADMINUI_EMAIL_PASSWORD=your-smtp-password
WGADMINUI_EMAIL_USE_TLS=True
WGADMINUI_EMAIL_USE_SSL=False
WGADMINUI_DEFAULT_FROM_EMAIL=noreply@example.com

# ── Site identity ────────────────────────────────────────────────────────────
# Display name shown in email subjects, page titles, and templates.
WGADMINUI_SITE_NAME=wgadminui

# ── Traefik ───────────────────────────────────────────────────────────────────
# These variables are used by docker-compose.yml to configure Traefik via
# Docker labels (Option A).  If Traefik cannot use Docker labels on your host
# (e.g. bare-metal Traefik or no shared Docker network), use the static file
# provider instead — see traefik/dynamic/wgadminui.toml.example for a ready-
# made template and the README "Traefik integration" section for instructions.

# The domain Traefik will route to this service (also used for email links)
WGADMINUI_DOMAIN=wgadminui.example.com

# Name of the Traefik ACME certificate resolver (configured in traefik.yml)
TRAEFIK_CERTRESOLVER=le

# Name of the external Docker network Traefik is on
TRAEFIK_NETWORK=traefik_network

# ── Optional tuning ───────────────────────────────────────────────────────────
WGADMINUI_GUNICORN_WORKERS=3
WGADMINUI_GUNICORN_TIMEOUT=60
WGADMINUI_LOG_LEVEL=INFO

# Set to True ONLY for local development over HTTP (disables WebAuthn origin check)
WGADMINUI_WEBAUTHN_ALLOW_INSECURE_ORIGIN=False

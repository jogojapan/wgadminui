# =============================================================================
# wgadminui — docker-compose.yml
#
# USAGE:
#   1. Copy .env.example to .env and edit all values.
#   2. Run:  docker compose up -d
#
# TRAEFIK INTEGRATION:
#   With network_mode: host, Traefik labels are still set but the container
#   does not join Docker networks. Traefik must be configured to reach the
#   app via the host's IP (or localhost if Traefik runs on the host).
#
#   Adjust the following labels to match your Traefik setup:
#     - traefik.http.routers.wgadminui.rule          (your hostname)
#     - traefik.http.routers.wgadminui.entrypoints   (your HTTPS entrypoint name)
#     - traefik.http.routers.wgadminui.tls.certresolver (your ACME resolver name)
#
# WIREGUARD ACCESS:
#   The container needs access to the host's WireGuard configuration.
#   /etc/wireguard is bind-mounted read-write so wgadminui can:
#     - Read the server .conf file to parse peers
#     - Write updated .conf files when new peers are added/removed
#     - Run `wg` commands (requires NET_ADMIN capability, set below)
#
#   IMPORTANT: After adding a peer, wgadminui calls `wg syncconf` to apply
#   changes live without restarting WireGuard. A full service restart is NOT
#   required for new peers to become active.
# =============================================================================

services:
  wgadminui:
    build:
      context: .
      dockerfile: Dockerfile
    image: wgadminui:latest
    container_name: wgadminui
    restart: unless-stopped

    # ── Host network mode ─────────────────────────────────────────────────
    # The container MUST share the host's network namespace so that `wg`
    # commands can see and manage the host's WireGuard interfaces (wg0, etc.).
    # Without this, `wg show wg0` fails with "No such device" because the
    # interface only exists in the host network namespace.
    #
    # Implications of network_mode: host:
    #   - ports: mapping is IGNORED — Gunicorn binds directly to host port 8000
    #   - networks: section is IGNORED — the container uses the host's stack
    #   - Traefik can still reach the app via the host's IP or localhost
    #   - WGADMINUI_PORT env var now controls the actual Gunicorn bind port
    network_mode: host

    # NET_ADMIN is required to run `wg` commands (add/remove peers, show status)
    cap_add:
      - NET_ADMIN

    volumes:
      # WireGuard configuration directory from the host — read-write
      # so wgadminui can update .conf files when peers change.
      - /etc/wireguard:/etc/wireguard

      # Persistent SQLite database storage
      - wgadminui_data:/app/data

    # ── Ports ─────────────────────────────────────────────────────────────
    # With network_mode: host, the ports: mapping is ignored.
    # Gunicorn binds directly to the host's port (controlled by WGADMINUI_PORT).
    # The port is documented here for clarity but has no effect at runtime.

    environment:
      # ── Core Django ─────────────────────────────────────────────────────
      # REQUIRED: Set a long random string. Generate with:
      #   python -c "import secrets; print(secrets.token_urlsafe(50))"
      WGADMINUI_SECRET_KEY: "${WGADMINUI_SECRET_KEY}"

      # Comma-separated list of hostnames this app is served at.
      # Include your Traefik domain and/or localhost.
      WGADMINUI_ALLOWED_HOSTS: "${WGADMINUI_ALLOWED_HOSTS:-localhost}"

      # Port gunicorn binds to on the host (with network_mode: host).
      WGADMINUI_PORT: "${WGADMINUI_PORT:-8000}"

      # Debug mode — MUST be False in production
      WGADMINUI_DEBUG: "${WGADMINUI_DEBUG:-False}"

      # Timezone for log timestamps and display (e.g. Europe/Berlin, UTC)
      WGADMINUI_TIME_ZONE: "${WGADMINUI_TIME_ZONE:-UTC}"

      # ── Initial admin account ────────────────────────────────────────────
      # Created automatically on first startup. Change password after login.
      WGADMINUI_ADMIN_EMAIL: "${WGADMINUI_ADMIN_EMAIL}"
      WGADMINUI_ADMIN_PASSWORD: "${WGADMINUI_ADMIN_PASSWORD}"

      # ── WireGuard ────────────────────────────────────────────────────────
      # Interface name (the .conf file in /etc/wireguard)
      WGADMINUI_WG_INTERFACE: "${WGADMINUI_WG_INTERFACE:-wg0}"

      # Server's public IP or hostname that clients will connect to
      WGADMINUI_WG_SERVER_PUBLIC_IP: "${WGADMINUI_WG_SERVER_PUBLIC_IP}"

      # WireGuard listen port on the server (must match [Interface] ListenPort)
      WGADMINUI_WG_SERVER_PORT: "${WGADMINUI_WG_SERVER_PORT:-51820}"

      # Path inside the container to the WireGuard conf directory
      WGADMINUI_WG_CONF_DIR: "/etc/wireguard"

      # ── Email / SMTP (required for invitation and verification emails) ───
      # Set WGADMINUI_EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend
      # in production. Default (console) only prints emails to stdout.
      WGADMINUI_EMAIL_BACKEND: "${WGADMINUI_EMAIL_BACKEND:-django.core.mail.backends.console.EmailBackend}"
      WGADMINUI_EMAIL_HOST: "${WGADMINUI_EMAIL_HOST:-localhost}"
      WGADMINUI_EMAIL_PORT: "${WGADMINUI_EMAIL_PORT:-587}"
      WGADMINUI_EMAIL_USER: "${WGADMINUI_EMAIL_USER:-}"
      WGADMINUI_EMAIL_PASSWORD: "${WGADMINUI_EMAIL_PASSWORD:-}"
      WGADMINUI_EMAIL_USE_TLS: "${WGADMINUI_EMAIL_USE_TLS:-True}"
      WGADMINUI_EMAIL_USE_SSL: "${WGADMINUI_EMAIL_USE_SSL:-False}"
      WGADMINUI_DEFAULT_FROM_EMAIL: "${WGADMINUI_DEFAULT_FROM_EMAIL:-noreply@example.com}"

      # ── Site identity ──────────────────────────────────────────────────
      # Display name used in email subjects, page titles, and templates.
      WGADMINUI_SITE_NAME: "${WGADMINUI_SITE_NAME:-wgadminui}"

      # Domain used for email links (verification, password reset, etc.)
      # and Traefik routing. Must match the public hostname of the app.
      WGADMINUI_DOMAIN: "${WGADMINUI_DOMAIN:-wgadminui.example.com}"

      # ── WebAuthn (passkeys) ──────────────────────────────────────────────
      # Set to True ONLY for local HTTP development (not for production)
      WGADMINUI_WEBAUTHN_ALLOW_INSECURE_ORIGIN: "${WGADMINUI_WEBAUTHN_ALLOW_INSECURE_ORIGIN:-False}"

      # ── Gunicorn tuning ──────────────────────────────────────────────────
      WGADMINUI_GUNICORN_WORKERS: "${WGADMINUI_GUNICORN_WORKERS:-3}"
      WGADMINUI_GUNICORN_TIMEOUT: "${WGADMINUI_GUNICORN_TIMEOUT:-60}"

      # ── Data directory ──────────────────────────────────────────────────
      # Path inside the container where the SQLite database is stored.
      # Must match the container-side target of the data volume mount.
      WGADMINUI_DATA_DIR: "${WGADMINUI_DATA_DIR:-/app/data}"

      # ── Logging ─────────────────────────────────────────────────────────
      WGADMINUI_LOG_LEVEL: "${WGADMINUI_LOG_LEVEL:-INFO}"

    # ── Traefik labels ───────────────────────────────────────────────────
    # With network_mode: host, Traefik must reach this container via the
    # host's IP (or localhost if Traefik also runs on the host).
    # The loadbalancer port must match the Gunicorn bind port.
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.wgadminui.rule=Host(`${WGADMINUI_DOMAIN:-wgadminui.example.com}`)"
      - "traefik.http.routers.wgadminui.entrypoints=websecure"
      - "traefik.http.routers.wgadminui.tls=true"
      - "traefik.http.routers.wgadminui.tls.certresolver=${TRAEFIK_CERTRESOLVER:-le}"
      - "traefik.http.services.wgadminui.loadbalancer.server.port=${WGADMINUI_PORT:-8000}"

    # With network_mode: host, the networks: section is ignored.
    # Traefik must be configured to reach the host's IP directly.
    # If Traefik runs in Docker, add an extra_hosts entry or use host.docker.internal.

# =============================================================================
# Volumes
# =============================================================================

volumes:
  wgadminui_data:
    # SQLite database + any runtime state
    # To backup: docker run --rm -v wgadminui_data:/data -v $(pwd):/backup \
    #   alpine tar czf /backup/wgadminui_backup.tar.gz /data
